{
  "public_api_bem_estoque_filtros": {
    "summary": "Listar filtros disponíveis do estoque público",
    "description": "Retorna as opções de filtro agregadas para a vitrine pública de estoque: categorias, subcategorias, UFs, cidades, bairros e comitentes, cada uma com a contagem de bens. Considera apenas bens ativos (cadastrado, em remoção, no pátio ou em leilão). Os filtros são encadeados: ao informar uma categoria, as subcategorias/UF/cidade/bairro/comitente já são restringidos por ela.",
    "parameters": [
      {"name": "leilao", "in": "query", "required": false, "schema": {"type": "string"}, "description": "ID do leilão para restringir a agregação."},
      {"name": "categoria", "in": "query", "required": false, "schema": {"type": "string"}, "description": "IDs de categorias (tipo pai) separados por vírgula."},
      {"name": "subcategoria", "in": "query", "required": false, "schema": {"type": "string"}, "description": "IDs de subcategorias (tipo) separados por vírgula."},
      {"name": "uf", "in": "query", "required": false, "schema": {"type": "string"}, "description": "UFs separadas por vírgula."},
      {"name": "cidade", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Cidades separadas por vírgula."},
      {"name": "bairro", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Bairros separados por vírgula."},
      {"name": "comitente", "in": "query", "required": false, "schema": {"type": "string"}, "description": "IDs de comitentes separados por vírgula."},
      {"name": "comitentes", "in": "query", "required": false, "schema": {"type": "string"}, "description": "IDs de comitentes separados por vírgula (alias de comitente; tem precedência sobre ele)."},
      {"name": "judicial", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Filtra por origem judicial."},
      {"name": "extrajudicial", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Filtra por origem extrajudicial."},
      {"name": "valorInicial", "in": "query", "required": false, "schema": {"type": "number"}, "description": "Valor mínimo para a faixa de preço."},
      {"name": "valorFinal", "in": "query", "required": false, "schema": {"type": "number"}, "description": "Valor máximo para a faixa de preço."}
    ]
  },
  "public_api_bem_list": {
    "summary": "Listar bens do estoque público",
    "description": "Lista paginada dos bens publicados no estoque público do site do leiloeiro, com vasto conjunto de filtros (veículo, imóvel, processo, datas, localização, valores etc.) e busca textual. Cada item traz a representação pública completa do bem (dados, fotos, comitente, campos extras, lotes). A resposta inclui também o bloco 'filtros' com as agregações de categorias/UF/cidade/bairro/comitente (mesmo conteúdo de /estoque/filtros).",
    "parameters": [
      {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "default": 1}, "description": "Página da listagem."},
      {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "default": 100}, "description": "Itens por página (limitado pelo máximo do servidor)."},
      {"name": "sortBy", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Campo de ordenação."},
      {"name": "descending", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Ordenação decrescente quando verdadeiro."},
      {"name": "id", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Filtra por ID do bem."},
      {"name": "comitentes", "in": "query", "required": false, "schema": {"type": "string"}, "description": "IDs de comitentes separados por vírgula."},
      {"name": "tipo", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Tipo do bem."},
      {"name": "marca", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Marca (veículo)."},
      {"name": "modelo", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Modelo (veículo)."},
      {"name": "ano", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Ano (veículo)."},
      {"name": "placa", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Placa (veículo)."},
      {"name": "chassi", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Chassi (veículo)."},
      {"name": "cor", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Cor."},
      {"name": "codigoFipe", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Código FIPE."},
      {"name": "data1", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data inicial do intervalo (usar com tipoData)."},
      {"name": "data2", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data final do intervalo (usar com tipoData)."},
      {"name": "tipoData", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Qual campo de data filtrar com data1/data2."},
      {"name": "dataEntrada1", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data de entrada inicial."},
      {"name": "dataEntrada2", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data de entrada final."},
      {"name": "dataSaida1", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data de saída inicial."},
      {"name": "dataSaida2", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Data de saída final."},
      {"name": "bloqueadoLeilao", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra bens bloqueados para leilão."},
      {"name": "alagamento", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra bens com indicação de alagamento."},
      {"name": "processoNumero", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Número do processo."},
      {"name": "processoExequente", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Exequente do processo."},
      {"name": "processoExecutado", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Executado do processo."},
      {"name": "processoInteligente", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Busca inteligente por processo."},
      {"name": "processo", "in": "query", "required": false, "schema": {"type": "string"}, "description": "ID/identificador do processo."},
      {"name": "numeroSinistro", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Número do sinistro (veículo)."},
      {"name": "search", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Termo de busca textual livre."},
      {"name": "vendaDireta", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra bens de venda direta."},
      {"name": "renavam", "in": "query", "required": false, "schema": {"type": "string"}, "description": "RENAVAM (veículo)."},
      {"name": "conservacao", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Estado de conservação."},
      {"name": "matricula", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Matrícula (imóvel)."},
      {"name": "uf", "in": "query", "required": false, "schema": {"type": "string"}, "description": "UF."},
      {"name": "cidade", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Cidade."},
      {"name": "endereco", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Endereço (imóvel)."},
      {"name": "bairro", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Bairro."},
      {"name": "cep", "in": "query", "required": false, "schema": {"type": "string"}, "description": "CEP (imóvel)."},
      {"name": "analiseCadastral", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Situação de análise cadastral."},
      {"name": "origem", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Origem do bem."},
      {"name": "evento", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Evento associado."},
      {"name": "emDeposito", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra bens em depósito."},
      {"name": "columns", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Colunas a retornar."},
      {"name": "response", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Formato de resposta."},
      {"name": "status", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Status do bem."},
      {"name": "categoria", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Categoria (tipo pai)."},
      {"name": "subcategoria", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Subcategoria (tipo)."},
      {"name": "judicial", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra bens de origem judicial."},
      {"name": "somenteAtivos", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Retorna apenas bens ativos."},
      {"name": "valorInicial", "in": "query", "required": false, "schema": {"type": "number"}, "description": "Valor mínimo."},
      {"name": "valorFinal", "in": "query", "required": false, "schema": {"type": "number"}, "description": "Valor máximo."},
      {"name": "destaque", "in": "query", "required": false, "schema": {"type": "boolean"}, "description": "Filtra apenas bens em destaque."}
    ]
  },
  "public_api_bem_show": {
    "summary": "Detalhar bem do estoque público",
    "description": "Retorna a representação pública completa de um único bem pelo seu ID, incluindo dados gerais, fotos/arquivos, comitente, campos extras, dados de veículo/imóvel e os lotes vinculados com seus leilões (datas e status). Usado na página de detalhe do bem na vitrine pública do site do leiloeiro.",
    "parameters": [
      {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}, "description": "ID do bem."}
    ]
  }
}
