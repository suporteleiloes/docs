{
  "category_create": {
    "summary": "Criar categoria de formulário",
    "description": "Cria uma nova categoria usada para classificar formulários no ERP. O corpo é validado pelo CategoryType (campos name e active). Retorna a categoria criada com status 201.",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Nome da categoria."
              },
              "active": {
                "type": "boolean",
                "description": "Indica se a categoria está ativa."
              }
            }
          }
        }
      }
    }
  },
  "category_list": {
    "summary": "Listar categorias de formulário",
    "description": "Lista as categorias de formulário ativas, ordenadas por nome em ordem ascendente. Retorna os registros em uma representação pública dentro de result.",
    "parameters": [
      {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {"type": "integer", "default": 1},
        "description": "Página da listagem (paginação)."
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {"type": "integer", "default": 100},
        "description": "Quantidade de registros por página."
      },
      {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": {"type": "integer"},
        "description": "Deslocamento inicial dos registros."
      },
      {
        "name": "search",
        "in": "query",
        "required": false,
        "schema": {"type": "string"},
        "description": "Termo de busca textual."
      },
      {
        "name": "active",
        "in": "query",
        "required": false,
        "schema": {"type": "string"},
        "description": "Filtra por situação (ativo/inativo); aceita o valor 0 para inativos."
      }
    ]
  },
  "category_show": {
    "summary": "Exibir categoria de formulário",
    "description": "Retorna os dados de uma categoria de formulário específica, na representação admin. Identificada pelo ID informado na URL.",
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {"type": "integer"},
        "description": "ID da categoria."
      }
    ]
  },
  "category_update": {
    "summary": "Atualizar categoria de formulário",
    "description": "Atualiza os dados de uma categoria de formulário existente. Aceita PUT e PATCH. O corpo é validado pelo CategoryType (campos name e active). Retorna a categoria atualizada.",
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {"type": "integer"},
        "description": "ID da categoria."
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Nome da categoria."
              },
              "active": {
                "type": "boolean",
                "description": "Indica se a categoria está ativa."
              }
            }
          }
        }
      }
    }
  }
}
