  "project_show": {
    "summary": "Detalhar projeto",
    "description": "Retorna os dados de um projeto específico. Exige que o usuário seja membro do projeto. Inclui as filas (queues) ativas globais e as do projeto, cada uma com a contagem de tarefas abertas, além de contadores agregados de tarefas: abertas, atribuídas ao usuário atual, não atribuídas, atrasadas e encerradas.",
    "parameters": [
      { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID do projeto." }
    ],
    "x-internal": true
  },
  "project_update": {
    "summary": "Atualizar projeto",
    "description": "Atualiza um projeto existente a partir dos campos enviados, validados via formulário. Aceita PUT (substituição) e PATCH (atualização parcial). Retorna o projeto atualizado.",
