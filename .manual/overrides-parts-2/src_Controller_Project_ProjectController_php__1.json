  "project_delete": {
    "summary": "Excluir projeto",
    "description": "Exclui (soft-delete) um projeto. A operação é bloqueada se houver tarefas vinculadas ao projeto, exigindo que elas sejam movidas ou encerradas antes. Retorna o projeto marcado como excluído.",
    "parameters": [
      { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID do projeto." }
