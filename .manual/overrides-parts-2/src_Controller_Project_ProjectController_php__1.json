{
  "project_create": {
    "summary": "Criar projeto",
    "description": "Cria um novo projeto no módulo de gestão de projetos/tarefas. Os dados são validados via formulário (nome, descrição, permissão, visibilidade pública, tipo, responsável, cliente, ativo). Se nenhum código for informado, um código único é gerado automaticamente. Retorna o projeto criado.",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "description": "Código do projeto. Se omitido, é gerado automaticamente." },
              "name": { "type": "string", "description": "Nome do projeto." },
              "description": { "type": "string", "description": "Descrição do projeto." },
              "permission": { "type": "string", "description": "Permissão/escopo de acesso do projeto." },
              "public": { "type": "boolean", "description": "Indica se o projeto é público." },
              "type": { "type": "string", "description": "Tipo do projeto." },
              "owner": { "type": "integer", "description": "Responsável/dono do projeto." },
              "client": { "type": "integer", "description": "Cliente associado ao projeto." },
              "active": { "type": "boolean", "description": "Indica se o projeto está ativo." }
            }
          }
        }
      }
    },
    "x-internal": true
  },
  "project_list": {
    "summary": "Listar projetos",
    "description": "Lista os projetos do módulo de gestão de projetos/tarefas, com paginação e diversos filtros. Usuários com perfil de suporte (ROLE_SUPORTE) têm a listagem restrita aos projetos dos quais são membros. Retorna a coleção paginada de projetos.",
    "parameters": [
      { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 }, "description": "Número da página." },
      { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 100 }, "description": "Quantidade de itens por página." },
      { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Deslocamento inicial dos resultados." },
      { "name": "sortBy", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Campo de ordenação." },
      { "name": "descending", "in": "query", "required": false, "schema": { "type": "boolean" }, "description": "Ordenação decrescente quando verdadeiro." },
      { "name": "id", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Filtra por ID do projeto." },
      { "name": "search", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Busca textual livre." },
      { "name": "cliente", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Filtra por cliente." },
      { "name": "lider", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Filtra por líder do projeto." },
      { "name": "visibilidade", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filtra por visibilidade." },
      { "name": "tipo", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filtra por tipo do projeto." },
      { "name": "chave", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filtra por chave/código." },
      { "name": "active", "in": "query", "required": false, "schema": { "type": "boolean" }, "description": "Filtra por status ativo." }
    ],
    "x-internal": true
  },
