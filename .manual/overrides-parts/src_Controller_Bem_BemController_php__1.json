      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "descricao": {"type": "string", "description": "Descrição/título principal do bem."},
              "identificador": {"type": "string", "description": "Identificador interno do bem."},
              "codigo": {"type": "string", "description": "Código do bem."},
              "tipo": {"type": "integer", "description": "ID do TipoBem."},
              "comitente": {"type": "integer", "description": "ID do comitente."},
              "status": {"type": "string", "description": "Status do bem."},
              "vendaDireta": {"type": "boolean", "description": "Bem em venda direta (sair de venda direta dispara webhook)."},
              "bloqueadoLeilao": {"type": "boolean", "description": "Bloqueia o bem para leilão (atualiza lotes ativos)."},
              "motivoBloqueio": {"type": "string", "description": "Motivo do bloqueio."},
              "processoNumero": {"type": "string", "description": "Número do processo (vincula a processo existente; esvaziar desvincula)."},
              "placa": {"type": "string", "description": "Placa do veículo."},
              "chassi": {"type": "string", "description": "Chassi do veículo."},
              "renavam": {"type": "string", "description": "Renavam."},
              "anoFabricacao": {"type": "integer", "description": "Ano de fabricação."},
              "anoModelo": {"type": "integer", "description": "Ano do modelo."},
              "ano": {"type": "integer", "description": "Alias legado; espelha para anoFabricacao/anoModelo quando vazios."},
              "dataSaida": {"type": "string", "format": "date-time", "description": "Data de saída (auto-preenchida ao sair de \"no pátio\" se configurado)."},
