              "pericias": {"type": "array", "items": {"type": "object"}, "description": "Coleção de perícias; itens omitidos são removidos."},
              "acessorios": {"type": "array", "items": {"type": "object"}, "description": "Coleção de acessórios; itens omitidos são removidos."},
              "camposExtras": {"type": "array", "items": {"type": "object"}, "description": "Campos extras do FormType (CampoExtraType)."},
              "tags": {"type": "array", "items": {"type": "object"}, "description": "Tags; substituem o conjunto atual. Cada item: {id} ou {isNew,value} ou id/nome."},
              "campos": {"type": "array", "items": {"type": "object"}, "description": "Valores de campos dinâmicos: {id?, campo:{id}, valor, valorExtra}."},
              "notificacoes": {"type": "array", "items": {"type": "object"}, "description": "Notificações jurídicas/postais (fora do FormType)."}
